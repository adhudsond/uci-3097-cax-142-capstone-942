# Copy this file to .env and adjust as needed.

# --- LLM provider ---
LLM_PROVIDER=ollama          # ollama | huggingface
LLM_MODEL=llama3             # e.g. llama3, mistral, gemma
OLLAMA_HOST=http://localhost:11434
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1024

# --- Vector store (ChromaDB) — optional RAG features ---
VECTOR_DB_PATH=data/chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
COLLECTION_NAME=it_processes

# --- Logging ---
LOG_LEVEL=INFO
